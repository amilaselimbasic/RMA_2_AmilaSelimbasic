<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="ba.moviecatalog">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ikona"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ikona"
        android:supportsRtl="true"
        android:theme="@style/Theme.MovieCatalog">

        <!-- Glavna aktivnost mora imati exported="true" -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Ostale aktivnosti nemaju intent-filter, pa exported nije obavezno -->
        <activity android:name=".MovieDetailsActivity" />
        <activity android:name=".ActorsActivity" />
        <activity android:name=".FavoritesActivity" />

    </application>
</manifest>
